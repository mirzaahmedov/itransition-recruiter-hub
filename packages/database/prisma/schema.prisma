// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CANDIDATE
  RECRUITER
  ADMINISTRATOR
}

model UserProfile {
  id        String @id @default(cuid())
  userId    String @unique
  user      User @relation(fields: [userId], references: [id])
  attrs     AttributeValue[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  googleId  String?  @unique
  role      UserRole
  profile   UserProfile?

  createdAt DateTime @default(now())

  @@map("users")
}

model AttributeCategory {
  id              String   @id @default(cuid())
  name            String?
  createdAt       DateTime @default(now())
  attributes      Attribute[]

  @@map("attribute_category")
}

enum AttributeType {
  TEXT
  MARKDOWN
  IMAGE
  NUMERIC
  DATE
  DATEPERIOD
  BOOLEAN
  CHOICE
}

model Attribute {
  id                    String   @id @default(cuid())
  name                  String
  type                  AttributeType
  categoryId            String
  category              AttributeCategory @relation(fields: [categoryId], references: [id])
  createdAt             DateTime @default(now())
  choices               AttributeChoice[]
  values                AttributeValue[]
  positionAttributes    PositionAttribute[]

  @@map("attributes")
}

model AttributeChoice {
  id              String @id @default(cuid())
  value           String
  attribute       Attribute @relation(fields: [attributeId], references: [id])
  attributeId     String
  createdAt       DateTime @default(now())
  
  values          AttributeValue[]

  @@unique([attributeId, value])
  @@map("attribute_choices")
}

model AttributeValue {
  id              String @id @default(cuid())
  
  attributeId     String
  attribute       Attribute @relation(fields: [attributeId], references: [id])

  textValue       String?
  numberValue     Float?
  booleanValue    Boolean?
  dateValue       DateTime?
  startDateValue  DateTime?
  endDateValue    DateTime?
  createdAt       DateTime @default(now())

  choiceId            String?
  choice          AttributeChoice? @relation(fields: [choiceId], references: [id])

  profileId       String
  profile         UserProfile @relation(fields: [profileId], references: [id])

  @@unique([attributeId, profileId])
  @@map("attribute_values")
}

model AccessRule {
  id                String @id @default(cuid())
  position          Position @relation(fields: [positionId], references: [id])
  positionId        String
}

model PositionAttribute {
  id                String @id @default(cuid())
  attribute         Attribute @relation(fields: [attributeId], references: [id])
  attributeId       String
  position          Position @relation(fields: [positionId], references: [id])
  positionId        String
}

model Position {
  id               String @id @default(cuid())
  title            String
  description      String

  accessRules      AccessRule[]
  attributes       PositionAttribute[]

  @@map("positions")
}

model CV {
  id              String @id @default(cuid())
  name            String
  email           String

  @@map("cvs")
}