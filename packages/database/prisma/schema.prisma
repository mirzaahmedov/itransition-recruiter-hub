// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CANDIDATE
  RECRUITER
  ADMINISTRATOR
}

model Category {
  id        String      @id
  name      String
  sortOrder Int
  attrs     Attribute[]

  @@map("categories")
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String?
  avatar       String?
  googleId     String?         @unique
  githubId     String?         @unique
  role         UserRole
  password     String?
  createdAt    DateTime        @default(now())

  profileAttrs UserAttribute[]
  projects     Project[]
  resumes      Resume[]
  likes        ResumeLike[]


  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  url         String?
  image       String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@map("projects")
}

enum AttributeType {
  TEXT
  MARKDOWN
  IMAGE
  NUMERIC
  DATE
  DATEPERIOD
  BOOLEAN
  CHOICE
}

model Attribute {
  id                 String              @id @default(cuid())
  name               String
  type               AttributeType
  system             Boolean             @default(false)
  categoryId         String
  category           Category            @relation(fields: [categoryId], references: [id])
  createdAt          DateTime            @default(now())
  choices            AttributeChoice[]
  values             UserAttribute[]
  positionAttributes PositionAttribute[]

  @@map("attributes")
}

model AttributeChoice {
  id          String          @id @default(cuid())
  value       String
  attribute   Attribute       @relation(fields: [attributeId], references: [id])
  attributeId String
  createdAt   DateTime        @default(now())
  values      UserAttribute[]

  @@unique([attributeId, value])
  @@map("attribute_choices")
}

model UserAttribute {
  id               String            @id @default(cuid())
  attributeId      String
  attribute        Attribute         @relation(fields: [attributeId], references: [id])
  textValue        String?
  numberValue      Float?
  booleanValue     Boolean?
  dateValue        DateTime?
  startDateValue   DateTime?
  endDateValue     DateTime?
  choiceId         String?
  choice           AttributeChoice?  @relation(fields: [choiceId], references: [id])
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  createdAt        DateTime          @default(now())
  version          Int               @default(1)
  resumeAttributes ResumeAttribute[]

  @@unique([attributeId, userId])
  @@map("user_attributes")
}

model AccessRule {
  id         String   @id @default(cuid())
  position   Position @relation(fields: [positionId], references: [id])
  positionId String
}

model PositionAttribute {
  id              String            @id @default(cuid())
  attribute       Attribute         @relation(fields: [attributeId], references: [id])
  attributeId     String
  position        Position          @relation(fields: [positionId], references: [id])
  positionId      String
  resumeAttribute ResumeAttribute[]
}

model Position {
  id          String              @id @default(cuid())
  title       String
  description String
  resumes     Resume[]
  accessRules AccessRule[]
  attributes  PositionAttribute[]

  @@map("positions")
}

enum ResumeStatus {
  PENDING
  PUBLISHED
}

model Resume {
  id               String            @id @default(cuid())
  positionId       String
  position         Position          @relation(references: [id], fields: [positionId], onDelete: Cascade)
  userId           String
  user             User              @relation(references: [id], fields: [userId], onDelete: Cascade)
  status           ResumeStatus      @default(PENDING)

  resumeAttributes ResumeAttribute[]
  likes            ResumeLike[]

  @@unique([userId, positionId])
  @@map("resumes")
}

model ResumeAttribute {
  id                  String            @id @default(cuid())
  resumeId            String
  resume              Resume            @relation(references: [id], fields: [resumeId], onDelete: Cascade)
  positionAttribute   PositionAttribute @relation(references: [id], fields: [positionAttributeId], onDelete: Cascade)
  positionAttributeId String
  userAttribute       UserAttribute     @relation(references: [id], fields: [userAttributeId], onDelete: Cascade)
  userAttributeId     String

  @@map("resume_attributes")
}

model ResumeLike {
  id                  String            @id @default(cuid())

  user                User              @relation(references: [id], fields: [userId], onDelete: Cascade)
  userId              String        

  resume              Resume            @relation(references: [id], fields: [resumeId], onDelete: Cascade)
  resumeId            String

  @@unique([userId, resumeId])
  @@map("resume_likes")    
}
