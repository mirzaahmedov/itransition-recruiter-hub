// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CANDIDATE
  RECRUITER
  ADMINISTRATOR
}

model Category {
  id        String @id
  name      String
  sortOrder Int
  
  attrs     Attribute[]

  @@map("categories")
}

model UserProfile {
  id        String @id @default(cuid())
  userId    String @unique
  user      User @relation(fields: [userId], references: [id])
  attrs     ProfileAttribute[]

  @@map("user_profiles")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  googleId  String?  @unique
  role      UserRole
  profile   UserProfile?
  password  String?

  createdAt DateTime @default(now())

  @@map("users")
}

enum AttributeType {
  TEXT
  MARKDOWN
  IMAGE
  NUMERIC
  DATE
  DATEPERIOD
  BOOLEAN
  CHOICE
}

model Attribute {
  id                    String   @id @default(cuid())
  name                  String
  type                  AttributeType
  system                Boolean  @default(false)
  categoryId            String
  category              Category @relation(fields: [categoryId], references: [id])
  createdAt             DateTime @default(now())
  choices               AttributeChoice[]
  values                ProfileAttribute[]
  positionAttributes    PositionAttribute[]

  @@map("attributes")
}

model AttributeChoice {
  id              String @id @default(cuid())
  value           String
  attribute       Attribute @relation(fields: [attributeId], references: [id])
  attributeId     String
  createdAt       DateTime @default(now())
  
  values          ProfileAttribute[]

  @@unique([attributeId, value])
  @@map("attribute_choices")
}

model ProfileAttribute {
  id              String @id @default(cuid())
  
  attributeId     String
  attribute       Attribute @relation(fields: [attributeId], references: [id])

  textValue       String?
  numberValue     Float?
  booleanValue    Boolean?
  dateValue       DateTime?
  startDateValue  DateTime?
  endDateValue    DateTime?

  choiceId        String?
  choice          AttributeChoice? @relation(fields: [choiceId], references: [id])

  profileId       String
  profile         UserProfile      @relation(fields: [profileId], references: [id])

  createdAt       DateTime         @default(now())
  version         Int              @default(1)

  @@unique([attributeId, profileId])
  @@map("attribute_values")
}

model AccessRule {
  id                String @id @default(cuid())
  position          Position @relation(fields: [positionId], references: [id])
  positionId        String
}

model PositionAttribute {
  id                String @id @default(cuid())
  attribute         Attribute @relation(fields: [attributeId], references: [id])
  attributeId       String
  position          Position @relation(fields: [positionId], references: [id])
  positionId        String
}

model Position {
  id               String @id @default(cuid())
  title            String
  description      String

  accessRules      AccessRule[]
  attributes       PositionAttribute[]

  @@map("positions")
}

model CV {
  id              String @id @default(cuid())
  name            String
  email           String

  @@map("cvs")
}