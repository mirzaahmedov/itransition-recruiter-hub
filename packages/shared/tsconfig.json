{
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    // File Layout
    "rootDir": "./src",
    "outDir": "./dist",

    // Environment Settings
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "sourceMap": false,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
